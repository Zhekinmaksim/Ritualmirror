NEXT_PUBLIC_RITUAL_RPC_URL=https://rpc.ritualfoundation.org
NEXT_PUBLIC_CHAIN_ID=1979
NEXT_PUBLIC_METADATA_BASE_URL=https://ritualmirror.xyz
NEXT_PUBLIC_HF_REPO_ID=yourname/ritual-mirror-workspace

# Fill after `pnpm contracts:deploy:ritual`.
NEXT_PUBLIC_REGISTRY_ADDRESS=
NEXT_PUBLIC_NFT_ADDRESS=
NEXT_PUBLIC_SOVEREIGN_CONSUMER_ADDRESS=
NEXT_PUBLIC_AGENT_MANAGER_ADDRESS=

# Optional external worker target. If omitted, Next API routes will use the built-in
# server-side status/chat handlers directly on Vercel.
RITUAL_WORKER_URL=http://127.0.0.1:8787
